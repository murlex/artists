<main class="page">
  {% if release.btsVideo %}
    <section class="video-bg video-bg--page" aria-hidden="true">
      <div class="video-bg__strip" data-video-density="{{ release.videoDensity or 'balanced' }}">
        <video class="video-bg__video" autoplay muted loop playsinline>
          <source src="{{ release.btsVideo | url }}" type="video/mp4">
        </video>
      </div>
      <div class="video-bg__overlay"></div>
    </section>
  {% else %}
    <section class="ambient-bg" aria-hidden="true">
      <div class="orb orb-one"></div>
      <div class="orb orb-two"></div>
      <div class="orb orb-three"></div>
    </section>
  {% endif %}

  <section class="hero shell">
    <h1>{{ site.title }}</h1>
    <p class="tagline">{{ site.tagline }}</p>
    {% if release.releaseDate %}
      <p class="hero-release" data-release-hide data-release-date="{{ release.releaseDateIso or release.releaseDate }}">{{ release.title }}</p>
      <p class="hero-release" hidden data-release-show data-release-date="{{ release.releaseDateIso or release.releaseDate }}">{{ release.title }} is released!</p>
    {% else %}
      <p class="hero-release">{{ release.title }}</p>
    {% endif %}
    {% if release.releaseDate %}
      <p class="release-date" data-release-hide data-release-date="{{ release.releaseDateIso or release.releaseDate }}">{{ release.releaseDate }}</p>
      <p
        class="release-countdown"
        data-release-countdown
        data-release-date="{{ release.releaseDateIso or release.releaseDate }}"
        hidden
        aria-live="polite"
      ></p>
    {% endif %}
    <a
      class="primary-cta track-event"
      href="{{ release.primaryCta.url }}"
      data-track-event="primary_cta_click"
      data-track-label="hero_{{ release.title | lower | replace(' ', '_') }}"
      data-release-hide
      data-release-cta
      data-release-date="{{ release.releaseDateIso or release.releaseDate }}"
      data-pre-label="{{ release.primaryCta.preReleaseLabel or 'Pre-Save' }}"
      data-live-label="{{ release.primaryCta.postReleaseLabel or 'Listen now!' }}"
      data-live-delay-seconds="{{ release.primaryCta.liveDelaySeconds or 30 }}"
      target="_blank"
      rel="noopener noreferrer"
    >{{ release.primaryCta.label }}</a>
    {% if release.primaryCta.microcopy %}
      <p class="cta-microcopy">{{ release.primaryCta.microcopy }}</p>
    {% endif %}
    {% if release.audioTeaser %}
      <div class="hero-teaser" data-release-hide data-release-date="{{ release.releaseDateIso or release.releaseDate }}">
        <p class="teaser-label">{{ release.audioTeaser.label or '🎵 Hear the opening' }}</p>
        <audio class="teaser-player" controls preload="none">
          <source src="{{ release.audioTeaser.src | url }}" type="audio/mpeg">
        </audio>
      </div>
    {% endif %}
    <div class="releases" hidden data-release-show data-release-date="{{ release.releaseDateIso or release.releaseDate }}">
      <article class="release-card">
        <h2>Listen Everywhere</h2>
        <div class="release-header">
          <h3>{{ release.title }}</h3>
        </div>
        {% if release.releaseDate %}
          <div class="release-meta">
            {% if release.releaseDate %}
              <p class="release-date small" data-release-hide data-release-date="{{ release.releaseDateIso or release.releaseDate }}">{{ release.releaseDate }}</p>
              <p
                class="release-countdown release-countdown-small"
                data-release-countdown
                data-release-date="{{ release.releaseDateIso or release.releaseDate }}"
                hidden
                aria-live="polite"
              ></p>
            {% endif %}
          </div>
        {% endif %}
        <div class="link-grid">
          {% for item in release.links %}
            <a
              class="link-card track-event"
              href="{{ item.url }}"
              data-track-event="outbound_stream_click"
              data-track-label="{{ release.title }}_{{ item.name }}"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="link-main">
                {% set name = item.name %}
                {% include "provider-icon.njk" %}
                <span class="link-name">{{ item.name }}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">→</span>
            </a>
          {% endfor %}
        </div>
        <p class="release-links-cta">
          <a
            class="primary-cta small track-event"
            href="{{ release.primaryCta.url }}"
            data-track-event="primary_cta_click"
            data-track-label="release_links_{{ release.title | lower | replace(' ', '_') }}"
            data-release-cta
            data-release-date="{{ release.releaseDateIso or release.releaseDate }}"
            data-pre-label="{{ release.primaryCta.preReleaseLabel or 'Pre-Save' }}"
            data-live-label="{{ release.primaryCta.postReleaseLabel or 'Listen now!' }}"
            data-live-delay-seconds="{{ release.primaryCta.liveDelaySeconds or 30 }}"
            target="_blank"
            rel="noopener noreferrer"
          >{{ release.primaryCta.label }}</a>
        </p>
      </article>
      {% if release.artwork and release.artwork.src %}
        <div class="hero-artwork">
          <a
            class="hero-artwork-link track-event"
            href="{{ release.primaryCta.url }}"
            data-track-event="primary_cta_click"
            data-track-label="hero_{{ release.title | lower | replace(' ', '_') }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open {{ release.title }}"
          >
            <picture>
              {% if release.artwork.srcMobile %}
                <source media="(max-width: 768px)" srcset="{{ release.artwork.srcMobile | url }}" />
              {% endif %}
              <img
                class="release-artwork"
                src="{{ release.artwork.src | url }}"
                alt="{{ release.artwork.alt or (release.title + ' artwork') }}"
                loading="eager"
                decoding="async"
              />
            </picture>
          </a>
        </div>
      {% endif %}
    </div>
  </section>

  <section class="social shell">
    <h2>Follow The Journey</h2>
    <div class="social-row">
      <a class="social-pill track-event" href="{{ site.social.instagram }}" data-track-event="social_click" data-track-label="instagram" target="_blank" rel="noopener noreferrer">{% set name = "Instagram" %}{% include "social-icon.njk" %}<span>Instagram</span></a>
      <a class="social-pill track-event" href="{{ site.social.youtube }}" data-track-event="social_click" data-track-label="youtube" target="_blank" rel="noopener noreferrer">{% set name = "YouTube" %}{% include "social-icon.njk" %}<span>YouTube</span></a>
      <a class="social-pill track-event" href="{{ site.social.tiktok }}" data-track-event="social_click" data-track-label="tiktok" target="_blank" rel="noopener noreferrer">{% set name = "TikTok" %}{% include "social-icon.njk" %}<span>TikTok</span></a>
    </div>
  </section>

  <section class="privacy shell" hidden>
    <h2>Tracking Preferences</h2>
    <p>
      This page can use Google Analytics 4 and Meta Pixel to measure link clicks and campaign performance.
    </p>
    <div class="consent-actions">
      <button id="consent-allow" class="consent-btn">Allow Tracking</button>
      <button id="consent-deny" class="consent-btn secondary">Decline Tracking</button>
    </div>
    <p class="consent-status" id="consent-status">No preference selected yet.</p>
  </section>
</main>