{% set platform = (name or "") | lower %}
{% set faviconDomain = "" %}
{% if "instagram" in platform %}
  {% set faviconDomain = "instagram.com" %}
{% elif "tiktok" in platform %}
  {% set faviconDomain = "tiktok.com" %}
{% elif "youtube" in platform %}
  {% set faviconDomain = "youtube.com" %}
{% elif "twitter" in platform or "x.com" in platform %}
  {% set faviconDomain = "x.com" %}
{% elif "facebook" in platform %}
  {% set faviconDomain = "facebook.com" %}
{% elif "bandcamp" in platform %}
  {% set faviconDomain = "bandcamp.com" %}
{% endif %}
<span class="social-icon social-favicon" aria-hidden="true">
  {% if faviconDomain %}
    <img src="https://www.google.com/s2/favicons?domain={{ faviconDomain }}&sz=32" alt="" width="18" height="18" loading="lazy">
  {% else %}
    <svg viewBox="0 0 24 24" focusable="false">
      <circle cx="12" cy="12" r="10" fill="currentColor"></circle>
      <path d="M10 8.2v8.1a2.1 2.1 0 1 1-1.4-2V9.2l6-1.2v6.5a2.1 2.1 0 1 1-1.4-2V6.8Z" fill="var(--surface)"></path>
    </svg>
  {% endif %}
</span>