{% set platform = (name or "") | lower %}
{% set iconPath = "" %}
{% if "instagram" in platform %}
  {% set iconPath = "/assets/img/icons/instagram.png" %}
{% elif "tiktok" in platform %}
  {% set iconPath = "/assets/img/icons/tiktok.png" %}
{% elif "youtube" in platform %}
  {% set iconPath = "/assets/img/icons/youtube.png" %}
{% elif "twitter" in platform or "x.com" in platform %}
  {% set iconPath = "/assets/img/icons/x.png" %}
{% elif "facebook" in platform %}
  {% set iconPath = "/assets/img/icons/facebook.png" %}
{% elif "bandcamp" in platform %}
  {% set iconPath = "/assets/img/icons/bandcamp.png" %}
{% endif %}
<span class="social-icon social-favicon" aria-hidden="true">
  {% if iconPath %}
    <img src="{{ iconPath | url }}" alt="" width="18" height="18" loading="lazy" decoding="async" />
  {% else %}
    <svg viewBox="0 0 24 24" focusable="false">
      <circle cx="12" cy="12" r="10" fill="currentColor"></circle>
      <path d="M10 8.2v8.1a2.1 2.1 0 1 1-1.4-2V9.2l6-1.2v6.5a2.1 2.1 0 1 1-1.4-2V6.8Z" fill="var(--surface)"></path>
    </svg>
  {% endif %}
</span>