<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ site.description }}" />
    <meta property="og:title" content="{{ site.title }}" />
    <meta property="og:description" content="{{ site.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ '/' | url }}" />
    <meta name="twitter:card" content="summary_large_image" />
    {% if release and (release.releaseDateIso or release.releaseDate) %}
      <script>
        (function () {
          var rawDate = {{ (release.releaseDateIso or release.releaseDate) | dump | safe }};
          var trimmed = String(rawDate || "").trim();
          var date = null;
          var isoMatch = trimmed.match(/^(\d{4})-(\d{2})-(\d{2})(?:[T\s](\d{2})(?::(\d{2})(?::(\d{2}))?)?)?(?:\.\d+)?(?:Z|[+-]\d{2}:?\d{2})?$/);

          if (isoMatch) {
            date = new Date(
              Number(isoMatch[1]),
              Number(isoMatch[2]) - 1,
              Number(isoMatch[3]),
              Number(isoMatch[4] || 0),
              Number(isoMatch[5] || 0),
              Number(isoMatch[6] || 0),
              0
            );
          } else {
            date = new Date(trimmed);
          }

          document.documentElement.dataset.releaseState = !Number.isNaN(date.getTime()) && Date.now() >= date.getTime() ? "live" : "upcoming";
        })();
      </script>
    {% endif %}
    {% if release and release.artwork and release.artwork.src %}
      <link
        rel="preload"
        as="image"
        href="{{ release.artwork.src | url }}"
        {% if release.artwork.srcMobile %}imagesrcset="{{ release.artwork.srcMobile | url }} 768w, {{ release.artwork.src | url }} 1200w"{% endif %}
      />
    {% endif %}
    <link rel="icon" type="image/svg+xml" sizes="any" href="{{ '/assets/img/favicon-planet.svg?v=3' | url }}" />
    <link rel="shortcut icon" type="image/svg+xml" href="{{ '/assets/img/favicon-planet.svg?v=3' | url }}" />
    <link rel="apple-touch-icon" href="{{ '/assets/img/favicon-planet.svg?v=3' | url }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="preload"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
  </head>
  <body>
    {{ content | safe }}
    {% include "analytics.njk" %}
    <script>
      (function () {
        function loadScript(src) {
          var script = document.createElement("script");
          script.src = src;
          script.defer = true;
          document.body.appendChild(script);
        }

        if (document.querySelector(".track-event")) {
          loadScript({{ ('/assets/js/tracking.js' | url) | dump | safe }});
        }

        if (document.querySelector(".video-bg__strip")) {
          loadScript({{ ('/assets/js/video-panels.js' | url) | dump | safe }});
        }

        if (document.querySelector("[data-release-countdown], [data-release-cta], [data-release-show], [data-release-hide]")) {
          loadScript({{ ('/assets/js/countdown.js' | url) | dump | safe }});
        }
      })();
    </script>
  </body>
</html>
