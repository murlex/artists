{% set provider = (name or "") | lower %}
{% set iconPath = "" %}
{% if "spotify" in provider %}
  {% set iconPath = "/assets/img/icons/spotify.png" %}
{% elif "apple" in provider %}
  {% set iconPath = "/assets/img/icons/apple-music.png" %}
{% elif "youtube music" in provider or ("youtube" in provider and "music" in provider) %}
  {% set iconPath = "/assets/img/icons/youtube-music.png" %}
{% elif "youtube" in provider %}
  {% set iconPath = "/assets/img/icons/youtube.png" %}
{% elif "soundcloud" in provider %}
  {% set iconPath = "/assets/img/icons/soundcloud.png" %}
{% elif "tidal" in provider %}
  {% set iconPath = "/assets/img/icons/tidal.png" %}
{% elif "deezer" in provider %}
  {% set iconPath = "/assets/img/icons/deezer.png" %}
{% elif "bandcamp" in provider %}
  {% set iconPath = "/assets/img/icons/bandcamp.png" %}
{% elif "amazon" in provider %}
  {% set iconPath = "/assets/img/icons/amazon-music.png" %}
{% endif %}
<span class="provider-icon provider-favicon" aria-hidden="true">
  {% if iconPath %}
    <img src="{{ iconPath | url }}" alt="" width="20" height="20" loading="lazy" decoding="async" />
  {% else %}
    <svg viewBox="0 0 24 24" focusable="false">
      <circle cx="12" cy="12" r="10" fill="currentColor"></circle>
      <path d="M10 8.2v8.1a2.1 2.1 0 1 1-1.4-2V9.2l6-1.2v6.5a2.1 2.1 0 1 1-1.4-2V6.8Z" fill="var(--surface)"></path>
    </svg>
  {% endif %}
</span>
