<script>
  window.APP_CONFIG = {
    ga4MeasurementId: "{{ site.analytics.ga4MeasurementId }}",
    metaPixelId: "{{ site.analytics.metaPixelId }}"
  };
</script>

<script>
  (function setupTrackingConsent() {
    var consent = localStorage.getItem("tracking-consent");
    if (!consent) {
      return;
    }

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }

    window.gtag = window.gtag || gtag;
    gtag("consent", "default", {
      analytics_storage: consent === "granted" ? "granted" : "denied",
      ad_storage: consent === "granted" ? "granted" : "denied"
    });
  })();
</script>
